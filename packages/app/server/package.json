{
  "name": "@rayspec/server",
  "version": "0.0.0",
  "private": true,
  "files": [
    "dist"
  ],
  "license": "FSL-1.1-ALv2",
  "type": "module",
  "description": "LOCAL/single-node production-style boot entrypoint + AppDeps composition root. Pre-external-hardening (no RLS/KMS/per-tenant isolate/DPoP) — NOT internet-facing. Assembles the platform from env, applies the committed migration chain via the real programmatic migrator, fails closed on missing secrets, and serves the Hono app.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "rayspec-serve": "./dist/serve.js"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "serve": "tsx src/serve.ts"
  },
  "dependencies": {
    "@hono/node-server": "2.0.6",
    "@rayspec/adapter-anthropic": "workspace:*",
    "@rayspec/adapter-codex": "workspace:*",
    "@rayspec/adapter-openai": "workspace:*",
    "@rayspec/adapter-pi": "workspace:*",
    "@rayspec/agent-runtime": "workspace:*",
    "@rayspec/api-auth": "workspace:*",
    "@rayspec/audio-runtime": "workspace:*",
    "@rayspec/auth-core": "workspace:*",
    "@rayspec/capability-bridges": "workspace:*",
    "@rayspec/conversation-runtime": "workspace:*",
    "@rayspec/core": "workspace:*",
    "@rayspec/db": "workspace:*",
    "@rayspec/durable-dbos": "workspace:*",
    "@rayspec/platform": "workspace:*",
    "@rayspec/product-yaml": "workspace:*",
    "@rayspec/spec": "workspace:*",
    "@rayspec/adapter-deepgram": "workspace:*",
    "@rayspec/stt-port": "workspace:*",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.26",
    "jose": "6.2.3",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@types/node": "22.12.0",
    "dotenv": "17.4.2",
    "postgres": "3.4.9",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "vitest": "4.1.9"
  }
}
