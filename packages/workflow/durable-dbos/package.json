{
  "name": "@rayspec/durable-dbos",
  "version": "0.0.0",
  "private": true,
  "license": "FSL-1.1-ALv2",
  "type": "module",
  "description": "The DBOS adapter for the neutral DurableExecutor. The ONLY package that imports @dbos-inc/dbos-sdk — @rayspec/platform / run-core / the adapters stay DBOS-free (engine asymmetry lives inside this adapter). Runs the EXISTING runAgent off-request inside one durable workflow; durability = whole-run re-execution (no step-resume).",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@rayspec/core": "workspace:*",
    "@rayspec/db": "workspace:*",
    "@rayspec/platform": "workspace:*",
    "@rayspec/workflow-durable": "workspace:*",
    "@rayspec/foundation": "workspace:*",
    "@dbos-inc/dbos-sdk": "4.21.6",
    "drizzle-orm": "0.45.2"
  },
  "devDependencies": {
    "@rayspec/grounding-runtime": "workspace:*",
    "@rayspec/spec": "workspace:*",
    "dotenv": "17.4.2",
    "postgres": "3.4.9",
    "typescript": "5.9.3",
    "vitest": "4.1.9"
  }
}
