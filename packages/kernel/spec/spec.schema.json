{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "additionalProperties": false
    },
    "stores": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 63,
            "pattern": "^[a-z_][a-z0-9_]*$"
          },
          "columns": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 63,
                  "pattern": "^[a-z_][a-z0-9_]*$"
                },
                "type": {
                  "type": "string",
                  "enum": [
                    "text",
                    "uuid",
                    "timestamp",
                    "integer",
                    "boolean",
                    "jsonb"
                  ]
                },
                "nullable": {
                  "default": false,
                  "type": "boolean"
                },
                "unique": {
                  "default": false,
                  "type": "boolean"
                },
                "enum": {
                  "minItems": 1,
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              "required": [
                "name",
                "type"
              ],
              "additionalProperties": false
            }
          },
          "foreignKeys": {
            "default": [],
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "column": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 63,
                  "pattern": "^[a-z_][a-z0-9_]*$"
                },
                "references": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 63,
                  "pattern": "^[a-z_][a-z0-9_]*$"
                },
                "referencesColumn": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 63,
                  "pattern": "^[a-z_][a-z0-9_]*$"
                },
                "onDelete": {
                  "default": "cascade",
                  "type": "string",
                  "enum": [
                    "cascade",
                    "restrict",
                    "set null"
                  ]
                }
              },
              "required": [
                "column",
                "references"
              ],
              "additionalProperties": false
            }
          },
          "softDelete": {
            "type": "boolean"
          }
        },
        "required": [
          "name",
          "columns"
        ],
        "additionalProperties": false
      }
    },
    "api": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "method": {
            "type": "string",
            "enum": [
              "GET",
              "POST",
              "PUT",
              "PATCH",
              "DELETE"
            ]
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "action": {
            "oneOf": [
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "store"
                  },
                  "store": {
                    "type": "string",
                    "minLength": 1
                  },
                  "op": {
                    "type": "string",
                    "enum": [
                      "list",
                      "get",
                      "create",
                      "update",
                      "delete"
                    ]
                  }
                },
                "required": [
                  "kind",
                  "store",
                  "op"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "agent"
                  },
                  "agent": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "kind",
                  "agent"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "handler"
                  },
                  "handler": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "kind",
                  "handler"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "stream"
                  },
                  "handler": {
                    "type": "string",
                    "minLength": 1
                  },
                  "mode": {
                    "type": "string",
                    "enum": [
                      "ingest",
                      "playback"
                    ]
                  }
                },
                "required": [
                  "kind",
                  "handler",
                  "mode"
                ],
                "additionalProperties": false
              }
            ]
          }
        },
        "required": [
          "method",
          "path",
          "action"
        ],
        "additionalProperties": false
      }
    },
    "agents": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "instructions": {
            "type": "string"
          },
          "model": {
            "type": "string",
            "minLength": 1
          },
          "outputSchema": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "schema": {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {}
              }
            },
            "required": [
              "name",
              "schema"
            ],
            "additionalProperties": false
          },
          "maxTurns": {
            "default": 8,
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "id": {
            "type": "string",
            "minLength": 1
          },
          "backend": {
            "type": "string",
            "enum": [
              "openai",
              "anthropic",
              "pi",
              "codex"
            ]
          },
          "tools": {
            "default": [],
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "requireNativeStructuredOutput": {
            "default": false,
            "type": "boolean"
          }
        },
        "required": [
          "name",
          "instructions",
          "model",
          "id",
          "backend"
        ],
        "additionalProperties": false
      }
    },
    "tooling": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "parameters": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          },
          "id": {
            "type": "string",
            "minLength": 1
          },
          "handler": {
            "type": "string",
            "minLength": 1
          },
          "idempotent": {
            "type": "boolean"
          },
          "timeoutMs": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "outputSchema": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          }
        },
        "required": [
          "name",
          "description",
          "parameters",
          "id",
          "handler",
          "idempotent",
          "timeoutMs"
        ],
        "additionalProperties": false
      }
    },
    "triggers": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "cron",
              "webhook",
              "event",
              "manual"
            ]
          },
          "schedule": {
            "type": "string",
            "minLength": 1
          },
          "event": {
            "type": "string",
            "minLength": 1
          },
          "action": {
            "oneOf": [
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "agent"
                  },
                  "agent": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "kind",
                  "agent"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "handler"
                  },
                  "handler": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "kind",
                  "handler"
                ],
                "additionalProperties": false
              }
            ]
          }
        },
        "required": [
          "name",
          "kind",
          "action"
        ],
        "additionalProperties": false
      }
    },
    "handlers": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "module": {
            "type": "string",
            "minLength": 1
          },
          "export": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "tool",
              "route",
              "trigger"
            ]
          }
        },
        "required": [
          "id",
          "module",
          "export",
          "kind"
        ],
        "additionalProperties": false
      }
    },
    "extensions": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "module": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[A-Za-z-][0-9A-Za-z-]*))*))?(?:\\+([0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*))?$"
          },
          "config": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          }
        },
        "required": [
          "id",
          "module",
          "version"
        ],
        "additionalProperties": false
      }
    },
    "deployment": {
      "type": "object",
      "properties": {
        "durableWorker": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "frontend": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "route": {
            "type": "string",
            "minLength": 1,
            "pattern": "^\\/"
          },
          "dir": {
            "type": "string",
            "minLength": 1
          },
          "spa": {
            "default": false,
            "type": "boolean"
          }
        },
        "required": [
          "route",
          "dir"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "version",
    "metadata"
  ],
  "additionalProperties": false
}
