# Dependencies
node_modules/
.pnpm-store/
.pnp.*
.yarn/*

# Build output
dist/
build/
out/
*.tsbuildinfo

# Exception: the notes-ui example ships a hand-written `web/dist` as a COMMITTED static fixture (the
# frontend-serving example serves + tests it). It is an example asset, not build output — re-include it.
!examples/notes-ui/web/dist/
!examples/notes-ui/web/dist/**

# Stray in-place-compiled `.js` inside an example extension-pack SOURCE root: packs are authored in
# `.ts` and built to `dist/`, but the compiled-module pack resolution prefers a sibling `.js` over the
# `.ts`, so an accidental in-place `tsc` output would shadow the source. Ignore it — no pack commits a
# `.js` under its source root (build output goes to `dist/`, already ignored above).
examples/**/packs/**/*.js

# Caches
.turbo/
.cache/
coverage/
.vitest/

# Dev-harness scratch (throwaway blob store written by example dev-boot scripts)
.dev-blobs/

# Env / secrets — never commit real credentials
.env
.env.*
!.env.example
*.pem
*-key.txt
openai-key.txt

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# IDE / OS
.DS_Store
.idea/
.vscode/
