# Dependencies
node_modules/
.pnpm-store/
.pnp.*
.yarn/*

# Build output
dist/
build/
out/
*.tsbuildinfo

# Exception: the notes-ui example ships a hand-written `web/dist` as a COMMITTED static fixture (the
# frontend-serving example serves + tests it). It is an example asset, not build output — re-include it.
!examples/notes-ui/web/dist/
!examples/notes-ui/web/dist/**

# Caches
.turbo/
.cache/
coverage/
.vitest/

# Dev-harness scratch (throwaway blob store written by example dev-boot scripts)
.dev-blobs/

# Env / secrets — never commit real credentials
.env
.env.*
!.env.example
*.pem
*-key.txt
openai-key.txt

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# IDE / OS
.DS_Store
.idea/
.vscode/
