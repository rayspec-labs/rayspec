# RaySpec — environment template.
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored and must
# NEVER be committed. Every value here is a placeholder — replace them.
#
# Only a subset is required to boot: a database URL, the two auth secrets, and at
# least one agent backend credential for whichever backend your spec uses. The
# rest are optional and only needed when the deployed spec declares the matching
# capability (audio/streams, playback, cron, erasure, ...).

# ─────────────────────────────────────────────────────────────────────────────
# Database (Postgres)
# ─────────────────────────────────────────────────────────────────────────────

# Main application database. Required. The bundled dev container (`pnpm db:up`)
# listens on port 5433; point this at your own Postgres in production.
# Also available as DATABASE_URL_FILE — see the file-mount section below.
DATABASE_URL=postgresql://rayspec:rayspec@localhost:5433/rayspec

# Throwaway shadow database used only for migration dry-runs. Required for the
# migration tooling; safe to point at an empty scratch database.
SHADOW_DATABASE_URL=postgresql://rayspec:rayspec@localhost:5433/rayspec_shadow

# Optional. The DBOS durable-worker SYSTEM database — a SEPARATE database from the
# app DB. Only used when the deployed spec enables the durable worker. If unset it
# is derived from DATABASE_URL by swapping the database name. Never point it at the
# app database.
# DBOS_SYSTEM_DATABASE_URL=postgresql://rayspec:rayspec@localhost:5433/rayspec_dbos_sys

# ─────────────────────────────────────────────────────────────────────────────
# Auth secrets (required at boot — the server fails closed without them)
# ─────────────────────────────────────────────────────────────────────────────

# HMAC pepper for API-key hashing. Use a long random per-environment value.
# Losing/rotating it invalidates every issued API key.
RAYSPEC_API_KEY_PEPPER=change-me-long-random-value

# RS256 JWT + OIDC signing key: a PKCS#8 PEM private key. The server refuses to
# boot without it. Generate a development key with:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048
# Paste the resulting PEM here (newline-escaped, single line). NEVER commit a real
# key; generate a fresh key per environment.
# RAYSPEC_JWT_SIGNING_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# ─────────────────────────────────────────────────────────────────────────────
# Reading the boot values from a file instead of the environment
# ─────────────────────────────────────────────────────────────────────────────
#
# Each of the three boot values above also accepts a <VAR>_FILE variant naming a
# file to read the value from — a mounted secret (mode 600) the server user can
# read:
#
#   DATABASE_URL_FILE=/run/secrets/database-url
#   RAYSPEC_JWT_SIGNING_KEY_FILE=/run/secrets/jwt-signing-key
#   RAYSPEC_API_KEY_PEPPER_FILE=/run/secrets/api-key-pepper
#
# WHY: the value stays out of the image, out of the compose file, out of the
# container's declared environment (so `docker inspect` does not show it), and
# out of the server's own exec environment in /proc/<pid>/environ. It also needs
# no wrapper entrypoint to materialize the secret into the environment first.
# The caveat, so this is not read for more than it says: at boot the server
# places the two AUTH secrets into its process environment for the components
# that read them there, so any child process it spawns is exec'd with them and
# they do appear in that child's /proc/<pid>/environ. The connection string is
# not placed there.
#
# WHERE: point these OUTSIDE the repository — a tmpfs or orchestrator secret
# mount such as /run/secrets/, or another path only the server user can read. A
# secret file inside a checkout is one `git add -f` away from being committed.
#
# PRECEDENCE: when <VAR>_FILE is set it WINS — the plain variable is not
# consulted at all. An empty / whitespace-only <VAR>_FILE counts as NOT SET (so
# an orchestrator that materializes an unset variable as "" keeps working) and
# the plain variable is used. A <VAR>_FILE left in a local .env therefore takes
# precedence for every component that resolves its configuration from the
# ambient environment.
#
# FAIL-CLOSED: if <VAR>_FILE is set but the file is missing, unreadable, a
# directory, or empty, the server ABORTS. It NEVER falls back to the plain
# variable — a broken secret mount must not silently downgrade to the weaker
# source. The abort names the variable, the path, and — when the read itself
# failed — the OS error code, never the file content.
#
# THE VARIABLE HOLDS A PATH, NOT THE SECRET. The abort messages quote that path
# so the error is actionable, which is a deliberate trade: a secret pasted into
# <VAR>_FILE by mistake is quoted back in the abort. Treat such a value as
# exposed and rotate it.
#
# CONTENT: the file holds the REAL bytes of the value. Surrounding whitespace is
# trimmed, so the trailing newline `echo`/`printf`/a secret projection appends is
# harmless — and for the pepper it must be, since the pepper IS the HMAC key and
# a stray newline would change every api-key hash. The flip side of the trim: a
# secret whose real bytes begin or end with whitespace cannot be expressed in
# the file form. That limit bites the two AUTH secrets, which are used exactly
# as written; the connection string is trimmed on the plain path as well, so
# moving one to DATABASE_URL_FILE cannot change its value. The signing-key file
# holds a REAL multi-line PEM with real newlines — NOT the single-line
# `\n`-escaped form the .env variable above uses. Create it so it is never
# readable by anyone else — the umask in the same subshell as the redirect AND a
# chmod afterwards. The two cover different failure modes: the umask constrains
# a file being CREATED, closing the window a later chmod would leave open, but
# it does not touch a file that already exists — a rotation onto a path an
# earlier key, a `touch`, or a configuration-management copy left group- or
# world-readable keeps that mode when `>` truncates it, and only the chmod
# corrects it.
#
#   (umask 077; openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 \
#     > /run/secrets/jwt-signing-key)
#   chmod 600 /run/secrets/jwt-signing-key
#
# SCOPE: <VAR>_FILE is a SERVER-BOOT mechanism — `rayspec-serve`, `rayspec
# deploy`, and anything else that boots the server read it. The CLI subcommands
# that need a database URL of their own (`rayspec plan`, `rayspec dev db`) read
# the plain DATABASE_URL only. `rayspec plan` compares SHADOW_DATABASE_URL
# against DATABASE_URL to refuse a migration dry-run that would run against the
# real database; with only DATABASE_URL_FILE set there is nothing to compare
# against, so that guard does not fire. Set the plain DATABASE_URL as well
# wherever you run those subcommands.
#
# The local development boot wrapper in examples/local-boot is BOTH. It requires
# all three plain variables of its own accord, because it provisions a throwaway
# dev database from DATABASE_URL before the resolver is ever reached — so a
# _FILE-only environment fails there first, early and loudly. It then points
# DATABASE_URL at that dev database and hands over to the ordinary server boot,
# which resolves from the ambient environment, where <VAR>_FILE still wins (see
# PRECEDENCE above). An ambient DATABASE_URL_FILE therefore outranks the dev
# database the wrapper just provisioned, while the boot banner still names the
# dev database. On a machine that has no such file the boot aborts fail-closed
# instead of retargeting anything silently; leave <VAR>_FILE out of a local .env
# unless you mean it for every boot.

# ─────────────────────────────────────────────────────────────────────────────
# Agent backends (supply the credential for whichever backend your spec uses)
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI. Serves BOTH the OpenAI backend AND the Pi backend (Pi runs on OpenAI).
OPENAI_API_KEY=sk-...
# Optional default model for the OpenAI/Pi backends.
# OPENAI_MODEL=

# Anthropic. The backend accepts EITHER credential, and reads it from THIS server
# process's own environment. The simplest path is your own Anthropic (Claude)
# Console API key (billed per token):
ANTHROPIC_API_KEY=

# Subscription OAuth token (from `claude setup-token`) — the subscription path
# instead of the API key. To use it, set ONLY this (leave ANTHROPIC_API_KEY empty)
# and set it HERE, in the server process's environment: the adapter runs each tenant
# under a FRESH CLAUDE_CONFIG_DIR that does NOT inherit a machine-level `claude`
# login, and a launcher/harness that scrubs child-process environments will strip
# it — so a working `claude` CLI login on the box is not enough. The SDK precedence
# is ANTHROPIC_API_KEY > CLAUDE_CODE_OAUTH_TOKEN: if BOTH are set, the API key wins
# and the API is billed (the subscription token is shadowed), and the boot logs a
# loud warning.
CLAUDE_CODE_OAUTH_TOKEN=

# Required whenever the Anthropic backend is used: a writable root directory under
# which the adapter creates a per-tenant CLAUDE_CONFIG_DIR (credentials + session
# state). Fail-closed at boot if the Anthropic backend is selected and this is unset.
# RAYSPEC_ANTHROPIC_CONFIG_ROOT=/var/lib/rayspec/anthropic

# Opt-in: reuse a machine `claude` login instead of a server-env token. On a box
# where a human has run `claude` login, set this truthy (true | 1 | on) to boot the
# Anthropic backend with NO token/key in the server env. You MUST seed each tenant's
# config dir first — copy the login into ${RAYSPEC_ANTHROPIC_CONFIG_ROOT}/tenant-<id>/
# — and RAYSPEC_ANTHROPIC_CONFIG_ROOT is still required. If a token/key is ALSO set it
# wins over the seeded login (and the boot warns). Unset ⇒ the fail-closed token demand
# above is unchanged. An unsupported value fails closed.
# RAYSPEC_ANTHROPIC_REUSE_LOGIN=false

# Codex backend. Codex authenticates from an on-disk credentials directory (where
# its `auth.json` lives), NOT from an env API key. Point CODEX_HOME at that
# directory. Leave empty to use the default (~/.codex).
CODEX_HOME=
# Optional default model for the Codex backend.
# CODEX_MODEL=

# ─────────────────────────────────────────────────────────────────────────────
# Speech-to-text (only if your spec declares an audio/transcription capability)
# ─────────────────────────────────────────────────────────────────────────────

# STT provider selector and its credential.
# STT_PROVIDER=deepgram
DEEPGRAM_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Runtime configuration (optional — sensible defaults apply)
# ─────────────────────────────────────────────────────────────────────────────

# HTTP listen port.
# PORT=8080

# Boot timeout in milliseconds (default 60000). The server assembles config, connects
# to the database, and applies the migration chain before it starts listening; if that
# step hangs (unreachable database, wrong DATABASE_URL, a stuck migration) the boot
# aborts after this many ms with a diagnostic instead of hanging silently. Raise it only
# if a legitimate boot is slower than the default.
# RAYSPEC_BOOT_TIMEOUT_MS=60000

# TCP listen host. LOOPBACK (127.0.0.1) by default — the LOCAL / pre-external-hardening server must
# not be reachable off-box. Set this (e.g. 0.0.0.0 for all interfaces) ONLY as a deliberate opt-in
# once the external-exposure hardening gate is met; the boot banner then logs the ACTUAL bound address.
# RAYSPEC_HOST=127.0.0.1

# Absolute path to the rayspec.yaml spec to deploy at boot. Absent ⇒ auth-only.
# RAYSPEC_SPEC_PATH=/absolute/path/to/rayspec.yaml

# CORS: exact allowed browser origins (comma-separated). EMPTY default = no
# cross-origin. Never set a permissive wildcard in production.
# ALLOWED_ORIGINS=https://app.example.com

# CORS: extra allowed request headers beyond the base set (comma-separated).
# ALLOWED_REQUEST_HEADERS=

# Trusted-proxy CIDRs (comma-separated) for rate-limit client-identity. EMPTY default =
# the socket peer is always the identity — no X-Forwarded-For / X-Real-IP header is trusted,
# so a direct caller cannot spoof its throttle identity. Set to your load-balancer / ingress
# hop CIDRs (e.g. 10.0.0.0/8) ONLY when the server sits behind a proxy you control.
# RAYSPEC_TRUSTED_PROXIES=

# Local filesystem root for the blob store (one subdirectory per tenant). Required
# only when the spec declares a binary/stream route.
# RAYSPEC_BLOB_ROOT=/var/lib/rayspec/blobs

# HS256 secret for signed media-playback tokens — SEPARATE from the JWT key, and
# at least 32 bytes. Required only when the spec declares a playback route.
# RAYSPEC_MEDIA_SIGNING_KEY=change-me-32-bytes-minimum

# The single deployment tenant (org id) every product-profile deploy binds to
# (single-node posture). Required by EVERY product deploy.
# RAYSPEC_PRODUCT_TENANT_ID=<org-uuid>

# Extraction executor mode — required when the deployed product declares agents:
#   live          = real agent runs (runAgent / gpt-5)
#   deterministic = injected executor (dev/CI only)
# RAYSPEC_EXTRACTION_MODE=live

# The tenant (org id) that the deployment's cron triggers fire under. Required
# only when the spec declares cron triggers on a durable worker.
# RAYSPEC_CRON_TENANT_ID=

# Operator gate for irreversible tenant data erasure. Enabled ONLY when set to the
# exact string "true"; anything else keeps erasure in dry-run (zero deletes).
# RAYSPEC_ERASURE_ENABLED=false
